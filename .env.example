# ── Instagram / Meta ──
META_PAGE_ACCESS_TOKEN=여기에_메타_페이지_액세스_토큰_입력
INSTAGRAM_BUSINESS_ACCOUNT_ID=여기에_인스타그램_비즈니스_계정_ID_입력

# ── YouTube ──
YOUTUBE_CLIENT_ID=여기에_유튜브_클라이언트_ID_입력
YOUTUBE_CLIENT_SECRET=여기에_유튜브_클라이언트_시크릿_입력
YOUTUBE_REFRESH_TOKEN=여기에_유튜브_리프레시_토큰_입력

# ── TikTok ──
TIKTOK_CLIENT_KEY=여기에_틱톡_클라이언트_키_입력
TIKTOK_CLIENT_SECRET=여기에_틱톡_클라이언트_시크릿_입력
TIKTOK_ACCESS_TOKEN=여기에_틱톡_액세스_토큰_입력
TIKTOK_REFRESH_TOKEN=여기에_틱톡_리프레시_토큰_입력

# ── Google Sheets ──
GOOGLE_SHEET_ID=여기에_구글시트_ID_입력
GOOGLE_SHEETS_CLIENT_ID=여기에_구글_클라이언트_ID_입력
GOOGLE_SHEETS_CLIENT_SECRET=여기에_구글_클라이언트_시크릿_입력
GOOGLE_SHEETS_REFRESH_TOKEN=여기에_구글시트_리프레시_토큰_입력

# ── Slack ──
SLACK_WEBHOOK_URL=여기에_슬랙_웹훅_URL_입력

# ── 설정 ──
POST_MAX_AGE_DAYS=90
